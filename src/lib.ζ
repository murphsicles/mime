// ── Internal helpers ────────────────────────────────────────────────────────

fn parseParams(s: []const u8) ![]Param {
    // Simple parser for "key=value; key=value"
    // In a real implementation this would use an allocator
    _ = s;
    return &[_]Param{};
}

fn attrsEqual(a: Attr, b: Attr) bool {
    return std.mem.eql(u8, a.as_str(), b.as_str());
}
